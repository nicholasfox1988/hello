<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>饮料订单系统 - 一键点单</title>
    <style>
        * {
            box-sizing: border-box;
            user-select: none; /* 避免点击按钮时意外选中文字，提升体验 */
        }

        body {
            font-family: system-ui, 'Segoe UI', 'Roboto', 'Helvetica Neue', sans-serif;
            background: linear-gradient(145deg, #f5f7fc 0%, #e9eef4 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0;
            padding: 20px;
        }

        /* 订单卡片容器 */
        .order-card {
            max-width: 680px;
            width: 100%;
            background: rgba(255, 255, 255, 0.96);
            border-radius: 48px;
            box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.2), 0 1px 3px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            backdrop-filter: blur(0px);
            transition: all 0.2s ease;
        }

        /* 头部区域 */
        .order-header {
            background: #1e2a3e;
            background-image: radial-gradient(circle at 10% 30%, #2c3e4e, #0f1a24);
            padding: 28px 24px 24px 24px;
            color: white;
        }

        .order-header h1 {
            margin: 0 0 6px 0;
            font-weight: 700;
            font-size: 1.9rem;
            letter-spacing: -0.3px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .order-header h1::before {
            content: "🧃";
            font-size: 2rem;
        }

        .sub {
            margin: 0;
            opacity: 0.8;
            font-size: 0.9rem;
            font-weight: 400;
        }

        /* 饮料按钮网格区域 */
        .beverage-grid {
            padding: 28px 24px 16px 24px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 18px;
            background: #ffffff;
            border-bottom: 1px solid #eef2f6;
        }

        /* 按钮样式 - 活泼的饮料卡片风格 */
        .drink-btn {
            background: #fefefe;
            border: 2px solid #e2e8f0;
            border-radius: 28px;
            padding: 16px 8px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            font-size: 1.2rem;
            font-weight: 600;
            color: #1f2a3e;
            transition: all 0.2s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            cursor: pointer;
            background: white;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.02);
        }

        .drink-btn:hover {
            transform: translateY(-5px);
            border-color: #cbdbe0;
            box-shadow: 0 12px 18px -8px rgba(0, 0, 0, 0.15);
            background: #fafcff;
        }

        .drink-btn:active {
            transform: translateY(2px);
            transition: 0.05s;
            background: #f1f5f9;
        }

        /* 每种饮料的小图标 + 文本行 */
        .drink-icon {
            font-size: 2.8rem;
            display: inline-block;
        }

        .drink-name {
            font-size: 1.1rem;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .click-badge {
            background: #eef2ff;
            border-radius: 40px;
            padding: 4px 12px;
            font-size: 0.7rem;
            font-weight: 500;
            color: #2c3e66;
            margin-top: 4px;
            transition: background 0.1s;
        }

        /* 订单明细区域 */
        .order-summary {
            padding: 20px 24px 28px 24px;
            background: #ffffff;
        }

        .summary-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1e293b;
            border-left: 5px solid #f97316;
            padding-left: 14px;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .order-list {
            background: #f8fafc;
            border-radius: 28px;
            padding: 8px 0;
            margin-bottom: 24px;
            box-shadow: inset 0 1px 3px #00000008, 0 2px 4px rgba(0, 0, 0, 0.02);
        }

        .order-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 20px;
            border-bottom: 1px solid #e2edf2;
            font-size: 1rem;
            transition: background 0.1s;
        }

        .order-item:last-child {
            border-bottom: none;
        }

        .item-info {
            display: flex;
            align-items: baseline;
            gap: 12px;
            flex-wrap: wrap;
        }

        .item-name {
            font-weight: 600;
            color: #0f172a;
            font-size: 1rem;
        }

        .item-quantity {
            background: white;
            padding: 2px 10px;
            border-radius: 40px;
            font-weight: 700;
            color: #f97316;
            font-size: 0.9rem;
            border: 1px solid #ffe0c4;
            min-width: 48px;
            text-align: center;
        }

        .item-controls {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        /* 微调按钮（增加/减少）保持风格一致，次要但清晰 */
        .adj-btn {
            background: #ffffff;
            border: 1px solid #cbd5e1;
            border-radius: 32px;
            width: 32px;
            height: 32px;
            font-size: 1.2rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: 0.1s linear;
            color: #1e293b;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }

        .adj-btn:hover {
            background: #f1f5f9;
            border-color: #f97316;
            color: #f97316;
        }

        .adj-btn:active {
            transform: scale(0.94);
            background: #e9eef3;
        }

        .delete-btn {
            background: none;
            border: none;
            font-size: 1.3rem;
            cursor: pointer;
            opacity: 0.55;
            transition: 0.1s;
            padding: 0 4px;
            border-radius: 30px;
        }

        .delete-btn:hover {
            opacity: 1;
            color: #e11d48;
            transform: scale(1.05);
        }

        /* 底部统计与操作 */
        .total-section {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            flex-wrap: wrap;
            gap: 15px;
            background: #ffffff;
            border-top: 2px dashed #e9edf2;
            padding-top: 20px;
            margin-top: 8px;
        }

        .total-items {
            font-weight: 500;
            background: #f1f4f9;
            padding: 6px 14px;
            border-radius: 30px;
            font-size: 0.85rem;
            color: #334155;
        }

        .total-amount {
            font-size: 1.7rem;
            font-weight: 800;
            color: #1f2a44;
            letter-spacing: -0.5px;
        }

        .total-amount span {
            font-size: 1rem;
            font-weight: 500;
            color: #5b6e8c;
        }

        .reset-btn {
            background: #f1f5f9;
            border: 1px solid #dce3ec;
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 500;
            color: #475569;
            cursor: pointer;
            transition: 0.15s;
            font-size: 0.85rem;
        }

        .reset-btn:hover {
            background: #eef2ff;
            border-color: #f97316;
            color: #f15a24;
        }

        /* 空状态提示 */
        .empty-msg {
            text-align: center;
            padding: 28px 20px;
            color: #94a3b8;
            font-weight: 500;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }

        /* 响应式小屏优化 */
        @media (max-width: 520px) {
            .beverage-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 12px;
                padding: 20px 16px;
            }
            .drink-btn {
                padding: 12px 4px;
            }
            .drink-icon {
                font-size: 2.2rem;
            }
            .order-summary {
                padding: 16px 18px 24px;
            }
            .total-amount {
                font-size: 1.4rem;
            }
        }
    </style>
</head>
<body>

<div class="order-card">
    <div class="order-header">
        <h1>快乐饮料站</h1>
        <p class="sub">点一下按钮，即刻加单 ✨ 随心畅饮</p>
    </div>

    <!-- 四种饮料按钮区域 -->
    <div class="beverage-grid" id="drinkButtonsContainer">
        <!-- 动态生成四个按钮 但为了方便阅读与维护，也可静态写，但使用js动态渲染确保结构一致，但依然遵循规范 -->
    </div>

    <!-- 订单详情汇总 -->
    <div class="order-summary">
        <div class="summary-title">
            📋 当前订单
        </div>
        <div id="orderListContainer" class="order-list">
            <!-- 动态订单列表展示 -->
            <div class="empty-msg">
                🍹 暂无饮料，点击上方按钮点单吧～
            </div>
        </div>
        
        <div class="total-section">
            <div class="total-items" id="totalItemsCount">总杯数: 0</div>
            <div class="total-amount">
                <span>💰</span> <span id="totalPrice">0</span> 元
            </div>
            <button class="reset-btn" id="resetOrderBtn">🗑️ 清空订单</button>
        </div>
    </div>
</div>

<script>
    // ---------- 饮料配置 ----------
    const BEVERAGES = [
        { id: 'cola', name: '可乐', price: 5, icon: '🥤', variant: '经典可乐' },
        { id: 'zeroCola', name: '无糖可乐', price: 6, icon: '🥤✨', variant: '无糖·零卡' },
        { id: 'sprite', name: '雪碧', price: 5, icon: '🍋', variant: '柠檬劲爽' },
        { id: 'fanta', name: '芬达', price: 5, icon: '🍊', variant: '橙味芬达' }
    ];

    // 初始订单数据 (存储每个饮料的数量 key: 饮料id)
    let orderMap = {
        cola: 0,
        zeroCola: 0,
        sprite: 0,
        fanta: 0
    };

    // ---------- DOM 元素 ----------
    const drinkContainer = document.getElementById('drinkButtonsContainer');
    const orderListContainer = document.getElementById('orderListContainer');
    const totalItemsSpan = document.getElementById('totalItemsCount');
    const totalPriceSpan = document.getElementById('totalPrice');
    const resetBtn = document.getElementById('resetOrderBtn');

    // ---------- 辅助函数 ----------
    // 计算总杯数 & 总金额
    function computeTotals() {
        let totalCups = 0;
        let totalMoney = 0;
        for (const bev of BEVERAGES) {
            const qty = orderMap[bev.id] || 0;
            totalCups += qty;
            totalMoney += qty * bev.price;
        }
        return { totalCups, totalMoney };
    }

    // 更新页面上的总杯数和总金额显示
    function updateTotalsDisplay() {
        const { totalCups, totalMoney } = computeTotals();
        totalItemsSpan.innerText = `总杯数: ${totalCups}`;
        totalPriceSpan.innerText = totalMoney;
    }

    // 核心: 渲染订单列表 (显示每个有数量的饮料，以及+/-/删除)
    function renderOrderList() {
        // 过滤出数量 > 0 的饮料项
        const activeOrders = BEVERAGES.filter(bev => (orderMap[bev.id] || 0) > 0);
        
        if (activeOrders.length === 0) {
            // 空状态显示
            orderListContainer.innerHTML = `
                <div class="empty-msg">
                    🧋 还没有点任何饮料～ <br> 点击上方按钮，美味即刻出发
                </div>
            `;
            updateTotalsDisplay();
            return;
        }
        
        // 构建订单列表 HTML
        let itemsHtml = '';
        for (const bev of activeOrders) {
            const qty = orderMap[bev.id];
            const subtotal = qty * bev.price;
            // 注意转义防止XSS (饮料名称都是安全文本)
            itemsHtml += `
                <div class="order-item" data-id="${bev.id}">
                    <div class="item-info">
                        <span class="item-name">${bev.icon} ${bev.name}</span>
                        <span class="item-quantity">× ${qty}</span>
                        <span style="color:#5b6e8c; font-size:0.85rem;">${subtotal}元</span>
                    </div>
                    <div class="item-controls">
                        <button class="adj-btn dec-btn" data-id="${bev.id}" data-op="decrement">−</button>
                        <button class="adj-btn inc-btn" data-id="${bev.id}" data-op="increment">+</button>
                        <button class="delete-btn" data-id="${bev.id}" data-op="delete" title="移除该饮料">🗑️</button>
                    </div>
                </div>
            `;
        }
        
        orderListContainer.innerHTML = itemsHtml;
        
        // 绑定订单列表内的按钮事件 (委托或者逐个绑定，这里采用事件委托，但直接在父级监听更优，不过先挂载后委托也可，为了方便在render后绑定)
        // 为了性能与可靠，使用事件委托监听orderListContainer上的点击
        // 但注意重复绑定委托会导致多个监听，我们可以在初始化时绑定一次委托，不用每次render都重新绑。
        // 为了避免重复绑定，已在页面初始化时全局委托监听。但是refresh后内容改变，委托依然有效，因为监听父容器。
        // 不过上面生成的按钮有类 .dec-btn / .inc-btn / .delete-btn ，委托监听依然可用。
        // 但注意必须在订单列表容器存在且父级监听。我们将在全局初始化时监听 orderListContainer，现在执行一次绑定（如果未绑定）。
        // 但要小心重复绑定，使用标志位，此处我们直接在外面绑定即可。
        
        updateTotalsDisplay();
    }
    
    // 修改某个饮料的数量 (delta: +1 或 -1)，如果减到0以下则归零
    function modifyQuantity(drinkId, delta) {
        if (!orderMap.hasOwnProperty(drinkId)) return false;
        let newVal = (orderMap[drinkId] || 0) + delta;
        if (newVal < 0) newVal = 0;
        orderMap[drinkId] = newVal;
        // 重新渲染订单列表 (同时更新总数)
        renderOrderList();
        return true;
    }
    
    // 直接设置数量 (用于删除)
    function setQuantity(drinkId, newQty) {
        if (!orderMap.hasOwnProperty(drinkId)) return;
        if (newQty < 0) newQty = 0;
        orderMap[drinkId] = newQty;
        renderOrderList();
    }
    
    // 清空整个订单
    function resetOrder() {
        for (let bev of BEVERAGES) {
            orderMap[bev.id] = 0;
        }
        renderOrderList();
        // 可选额外反馈轻提示（无强制要求，简单清新）
    }
    
    // 渲染饮料按钮 (四个大按钮，每个按钮点一下增加对应饮料数量)
    function renderDrinkButtons() {
        if (!drinkContainer) return;
        let btnsHtml = '';
        for (const bev of BEVERAGES) {
            btnsHtml += `
                <button class="drink-btn" data-id="${bev.id}" data-name="${bev.name}" data-price="${bev.price}">
                    <div class="drink-icon">${bev.icon}</div>
                    <div class="drink-name">${bev.name}</div>
                    <div class="click-badge">点击 +1</div>
                </button>
            `;
        }
        drinkContainer.innerHTML = btnsHtml;
        
        // 绑定饮料按钮的点击事件 (直接选择所有 .drink-btn)
        const drinkBtns = document.querySelectorAll('.drink-btn');
        drinkBtns.forEach(btn => {
            // 避免重复绑定，使用新监听，但先移除旧的可能，因为每次render会重建，直接添加即可，无重复问题。
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const drinkId = btn.getAttribute('data-id');
                if (drinkId && orderMap.hasOwnProperty(drinkId)) {
                    // 增加数量
                    modifyQuantity(drinkId, 1);
                    // 微交互动画：按钮闪烁效果（可选简单体验）
                    btn.style.transform = 'scale(0.97)';
                    setTimeout(() => {
                        if (btn) btn.style.transform = '';
                    }, 120);
                }
            });
        });
    }
    
    // ---------- 全局事件委托: 处理订单列表内的 增加/减少/删除 操作 ----------
    function setupOrderListDelegation() {
        if (!orderListContainer) return;
        orderListContainer.addEventListener('click', (e) => {
            // 向上查找实际按钮元素
            let targetEl = e.target;
            // 判断点击的元素是否是按钮或包含按钮类
            const decBtn = targetEl.closest('.dec-btn');
            const incBtn = targetEl.closest('.inc-btn');
            const delBtn = targetEl.closest('.delete-btn');
            
            if (decBtn) {
                const drinkId = decBtn.getAttribute('data-id');
                if (drinkId) {
                    modifyQuantity(drinkId, -1);
                    // 增加触感反馈
                    decBtn.style.transform = 'scale(0.9)';
                    setTimeout(() => { if(decBtn) decBtn.style.transform = ''; }, 100);
                }
                e.preventDefault();
            }
            else if (incBtn) {
                const drinkId = incBtn.getAttribute('data-id');
                if (drinkId) {
                    modifyQuantity(drinkId, 1);
                    incBtn.style.transform = 'scale(0.9)';
                    setTimeout(() => { if(incBtn) incBtn.style.transform = ''; }, 100);
                }
                e.preventDefault();
            }
            else if (delBtn) {
                const drinkId = delBtn.getAttribute('data-id');
                if (drinkId) {
                    // 删除: 将数量置为0
                    setQuantity(drinkId, 0);
                    delBtn.style.transform = 'scale(0.9)';
                    setTimeout(() => { if(delBtn) delBtn.style.transform = ''; }, 100);
                }
                e.preventDefault();
            }
        });
    }
    
    // 重置按钮监听
    function setupResetButton() {
        if (resetBtn) {
            resetBtn.addEventListener('click', () => {
                resetOrder();
                // 轻微动画
                resetBtn.style.transform = 'scale(0.96)';
                setTimeout(() => { if(resetBtn) resetBtn.style.transform = ''; }, 150);
            });
        }
    }
    
    // 可选: 初始展示可能有demo默认展示一个示例订单让页面更生动 (但保留完全空白)
    // 为了演示效果，可以预置一杯可乐展示界面非空 (但题目没有要求，不过让页面直观也可以, 不影响核心: 点一下增加)
    // 根据通常用户心理，展示样例可以更友好，但无伤大雅，但为了严格符合“点一下就增加一下”，初始为空也是完全ok。
    // 但为空时订单列表展示友好提示，用户点按钮增加就能看到订单。 完全满足要求。
    // 但我们可以不预设任何数量，完全让用户第一次点击触发。
    // 已经满足需求: 可乐、无糖可乐、雪碧、芬达四个按钮，点击一下数量+1。
    
    // 初始化整个页面: 渲染按钮，渲染订单列表(空)，设置委托，重置按钮监听
    function init() {
        renderDrinkButtons();          // 生成四个饮料大按钮
        renderOrderList();            // 初始订单为空列表
        setupOrderListDelegation();   // 委托事件处理订单区域内的 + - 删除
        setupResetButton();           // 清空按钮
        
        // 添加额外微小优化: 键盘或触摸无延迟
    }
    
    // 启动所有
    init();
</script>
</body>
</html>